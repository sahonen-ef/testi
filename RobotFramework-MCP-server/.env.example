# RobotFramework MCP Server Configuration
# Copy this file to .env and update the paths for your project

# Project Configuration
# ====================

# Path to your Robot Framework test files
# This directory will be mounted as read-only inside the container at /tests
# Example: /home/user/myproject/tests or C:\Users\myuser\myproject\tests
TESTS_DIR=./robot_tests

# Path to store test results
# This directory will be mounted as read-write inside the container at /results
# Example: /home/user/myproject/results or C:\Users\myuser\myproject\results
RESULTS_DIR=./robot_results

# Container Configuration
# =======================

# Name of the Docker container
CONTAINER_NAME=RobotFramework-mcp-persistent

# Name of the Docker image
IMAGE_NAME=robotframework-mcp:latest

# Network Configuration
# =====================

# Network mode for the container (host, bridge, or custom network name)
# Use 'host' to access services running on localhost from within the container
# On Windows/Mac Docker Desktop, 'host' mode allows container to reach host services
NETWORK_MODE=host

# Optional: Custom network name (leave empty to use NETWORK_MODE setting)
# CUSTOM_NETWORK=myproject_network

# Robot Framework Test Configuration
# ===================================

# DEFAULT LIBRARY: Robot Framework Browser Library (Playwright-based)
# This MCP server is pre-configured with Browser library for modern web testing
# Browser library is faster and more reliable than SeleniumLibrary

# Default browser for Robot Framework Browser library
# Options: chromium, firefox, webkit
BROWSER=chromium

# Run browser in headless mode (true/false)
# IMPORTANT: In Docker environments, headless mode MUST be 'true'
# Docker containers have no display server, so non-headless mode will fail
# Unless you configure X11 forwarding (advanced), keep this as 'true'
HEADLESS=true

# Base URL for your application under test (if applicable)
# This can be overridden in individual test runs or in your Robot files
# BASE_URL=http://localhost:8000

# Advanced Configuration
# ======================

# Timezone for the container
TZ=Europe/Helsinki

# Output directory inside container (usually don't need to change)
ROBOT_OUTPUT_DIR=/tmp/results

# Tests directory inside container (usually don't need to change)
RF_TESTS_DIR=/tests
